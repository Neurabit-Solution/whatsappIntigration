          "item": [
            {
              "name": "GET List message templates (Meta)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "x-api-key",
                    "value": "{{apiKey}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/templates",
