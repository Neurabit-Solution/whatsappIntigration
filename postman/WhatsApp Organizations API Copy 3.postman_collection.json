    {
      "name": "Webhook (Meta)",
      "item": [
        {
          "name": "GET Webhook verification (hub.challenge)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/webhook/{{webhookApiKey}}?hub.mode=subscribe&hub.verify_token={{webhookVerifyToken}}&hub.challenge={{hubChallenge}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "webhook",
                "{{webhookApiKey}}"
              ],
              "query": [
                {
                  "key": "hub.mode",
                  "value": "subscribe"
                },
                {
                  "key": "hub.verify_token",
                  "value": "{{webhookVerifyToken}}"
                },
                {
                  "key": "hub.challenge",
                  "value": "{{hubChallenge}}"
                }
              ]
            },
            "description": "Meta calls this when you add the webhook URL.\n\nSet env values:\n- `webhookApiKey` = organization apiKey\n- `webhookVerifyToken` = organization whatsapp verifyToken\n- `hubChallenge` = any string\n\n**Success:** response body exactly equals `hubChallenge`.\n\n**Failure:** 403."
          },
          "response": []
        },
        {
          "name": "POST Webhook (sample inbound + status)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const appSecret = (pm.environment.get('whatsappAppSecret') || '').trim();",
                  "const raw = pm.request.body && pm.request.body.raw ? pm.request.body.raw : '{}';",
                  "if (!appSecret) {",
                  "  pm.request.headers.remove('X-Hub-Signature-256');",
                  "} else {",
                  "  const digest = CryptoJS.HmacSHA256(raw, appSecret).toString(CryptoJS.enc.Hex);",
                  "  pm.request.headers.upsert({ key: 'X-Hub-Signature-256', value: `sha256=${digest}` });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"WABA_ID\",\n      \"changes\": [\n        {\n          \"field\": \"messages\",\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": {\n              \"display_phone_number\": \"15550000000\",\n              \"phone_number_id\": \"{{phoneNumberId}}\"\n            },\n            \"contacts\": [\n              {\n                \"profile\": { \"name\": \"Test User\" },\n                \"wa_id\": \"15551234567\"\n              }\n            ],\n            \"messages\": [\n              {\n                \"from\": \"15551234567\",\n                \"id\": \"wamid.inbound-example\",\n                \"timestamp\": \"1234567890\",\n                \"type\": \"text\",\n                \"text\": { \"body\": \"Hello\" }\n              }\n            ],\n            \"statuses\": [\n              {\n                \"id\": \"wamid.outbound-example\",\n                \"status\": \"delivered\",\n                \"timestamp\": \"1234567890\",\n                \"recipient_id\": \"15551234567\"\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/{{webhookApiKey}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "webhook",
                "{{webhookApiKey}}"
              ]
            },
            "description": "Simulates Meta’s webhook payload.\n\n- Uses `{{phoneNumberId}}`; it must match organization `whatsapp.phoneNumberId`.\n- Inbound `messages` upserts Leads.\n- `statuses` updates outbound `Message` by `metaMessageId`.\n\nUse a real `metaMessageId` from a prior send to test delivery updates.\n\nIf server env has `WHATSAPP_APP_SECRET`, this request must include valid `X-Hub-Signature-256` like Meta."
          },
          "response": []
        }
