MONGODB_URI=mongodb://127.0.0.1:27017/whatsapp_multi_organization
PORT=3000
JWT_SECRET=change-me-for-future-auth

# Required for organization provisioning APIs:
# - POST /api/organizations
# - PATCH /api/organizations/:id/whatsapp
# Must match Postman variable `adminKey` (see postman/WhatsApp-Organizations-API.postman_environment.json)
# Or send header: X-Admin-Key, or Authorization: Bearer <same value>
ADMIN_API_KEY=change-me-long-random-secret

# Optional (recommended in production): validate Meta webhook signature (X-Hub-Signature-256)
# Set this to your Meta app's App Secret.
WHATSAPP_APP_SECRET=

# Optional: max in-memory webhook debug entries for GET /api/webhook-logs (default 500)
# WEBHOOK_LOG_MAX=500

# Optional but required if you want inbound / status events mirrored into LightLeads Firestore.
# Preferred setup in production:
# 1) Set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON file path, OR
# 2) Provide the service account below, OR
# 3) Provide FIREBASE_SERVICE_ACCOUNT_JSON as one JSON string.
#
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
