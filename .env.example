MONGODB_URI=mongodb://127.0.0.1:27017/whatsapp_multi_organization
PORT=3000
# Docker / nginx: the container must listen on the same port you publish (e.g. docker run -p 3003:3000 requires PORT=3000).
# If your deploy uses -p 3003:10000, then PORT inside the container must be 10000 or nginx will get 502.
JWT_SECRET=change-me-for-future-auth

# Required for organization provisioning APIs:
# - POST /api/organizations
# - PATCH /api/organizations/:id/whatsapp
# Must match Postman variable `adminKey` (see postman/WhatsApp-Organizations-API.postman_environment.json)
# Or send header: X-Admin-Key, or Authorization: Bearer <same value>
ADMIN_API_KEY=change-me-long-random-secret

# Optional (recommended in production): validate Meta webhook signature (X-Hub-Signature-256)
# Set this to your Meta app's App Secret.
WHATSAPP_APP_SECRET=

# Optional: max in-memory webhook debug entries for GET /api/webhook-logs (default 500)
# WEBHOOK_LOG_MAX=500

# Optional but required if you want inbound / status events mirrored into LightLeads Firestore.
# Preferred setup in production:
# 1) Set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON file path, OR
# 2) Provide the service account below, OR
# 3) Provide FIREBASE_SERVICE_ACCOUNT_JSON as one JSON string.
#
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Required for mirroring inbound + delivery status into LightLeads Firestore WITHOUT collectionGroup queries:
# Set this to the Firebase Auth uid of the LightLeads user who owns whatsappCampaigns (same as request.auth.uid in Cloud Functions).
# FIREBASE_SYNC_UID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional if LightLeads functions write whatsappCrmInboundRouting/{WHATSAPP_ORGANIZATION_ID} (see WHATSAPP_ORGANIZATION_ID in Firebase function params).
# Optional: multiple uids (comma / space separated)
# FIREBASE_SYNC_UIDS=uid1,uid2
#
# Optional: limit campaign scanning (default 50, max 200)
# FIREBASE_SYNC_CAMPAIGN_SCAN_LIMIT=50
#
# Optional: only scan these campaign document ids (skips orderBy scan; safest if you have many campaigns)
# FIREBASE_SYNC_CAMPAIGN_IDS=8eFuWOHvwZQ8DA30eAYF
#
# Optional: re-enable collectionGroup fallback (default off). Only turn on after Firestore indexes exist.
# FIREBASE_USE_COLLECTION_GROUP=false
#
# Firestore security rules: the service account must be allowed to read/write
# users/{uid}/whatsappCampaigns/.../conversations/.../messages (otherwise you will see PERMISSION_DENIED in logs).
